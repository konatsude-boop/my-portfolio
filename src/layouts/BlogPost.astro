---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

// 既存のコードはそのままで、先頭部分に追加
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== Astro.props.id)
  .slice(0, 2);

---

<html lang="en">
	<head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
		<BaseHead title={title} description={description} />
		<style>
main {
  width: calc(100% - 2em);
  max-width: 100%;
  margin: 0 auto;  /* 左右を自動にして中央寄せ */
  padding-top: 6vh;
}
.hero-image {
  width: 100%;
}
.hero-image img {
  display: block;
  margin: 0 auto;
  border-radius: 20px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  max-width: 600px; /* これを追加 */
  width: 100%;
  height: auto
}
.prose {
  width: 720px;
  max-width: calc(100% - 2em);
  margin: auto;
  padding: 1em;
  color: rgb(var(--gray-dark));
  line-height: 1.9;
}
.title {
  margin-bottom: 1.5em;
  padding: 2em 0 1.5em;
  text-align: center;
  line-height: 1;
}
.title h1 {
  margin: 0.3em 0 0;
  font-size: 1.8rem;
}
.date {
  margin-bottom: 0.5em;
  color: #b88a8f;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
}
.last-updated-on {
  font-style: italic;
}
.title hr {
  border: none;
  border-top: 2px solid #f0d9db;
  width: 60px;
  margin: 1.5em auto 0;
}
.related {
  width: 720px;
  max-width: calc(100% - 2em);
  margin: 3em auto;
  padding: 1em;
}
.related h2 {
  font-size: 1.2rem;
  margin-bottom: 1.2em;
  text-align: center;
}
.related-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.2em;
}
.related-grid a {
  display: block;
  padding: 1.2em;
  border: none;
  border-radius: 16px;
  background: #fdf6f3;
  text-decoration: none;
  color: rgb(var(--black));
  box-shadow: 0 4px 14px rgba(224,166,171,0.15);
  transition: transform 0.25s ease;
}
.related-grid a:hover {
  transform: translateY(-3px);
}
.related-title {
  font-weight: 600;
  margin: 0 0 0.5em;
}
.related-date {
  font-size: 0.8em;
  color: #b88a8f;
  margin: 0;
}
.prose h1 {
  font-size: 1.6rem;
  margin: 3em 0 1em;
  text-align: center;
}
.prose h2 {
  font-size: 1.15rem;
  margin: 2.5em 0 1.2em;
  padding-bottom: 0.5em;
  border-bottom: 2px solid #f0d9db;
  color: rgb(var(--gray-dark));
}

/* スキルバー */
.skill-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.skill-item {
  display: flex;
  align-items: center;
  gap: 1.2em;
  margin-bottom: 1.1em;
}
.skill-name {
  width: 120px;
  flex-shrink: 0;
  font-size: 0.9rem;
  font-weight: 600;
}
.bar-track {
  flex: 1;
  height: 8px;
  background: #f5e6e7;
  border-radius: 20px;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #f0b8bd, #e0a6ab);
  border-radius: 20px;
}

/* タイムライン */
.timeline {
  list-style: none;
  padding: 0;
  margin: 0;
}
.timeline-item {
  display: flex;
  gap: 1.8em;
  margin-bottom: 1.8em;
  position: relative;
}
.timeline-item::before {
  content: '';
  position: absolute;
  left: 68px;
  top: 6px;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: #e0a6ab;
}
.timeline-year {
  width: 60px;
  flex-shrink: 0;
  font-size: 0.85rem;
  color: #b88a8f;
  font-weight: 600;
  padding-top: 2px;
  text-align: right;
}
.timeline-content {
  padding-left: 1.2em;
  border-left: 2px solid #f0d9db;
  padding-bottom: 0.3em;
}
.timeline-content h3 {
  margin: 0 0 0.3em;
  font-size: 1rem;
}
.timeline-content p {
  margin: 0;
  font-size: 0.9rem;
  color: rgb(var(--gray-dark));
}
@media (max-width: 720px) {
  .related-grid {
    grid-template-columns: 1fr;
  }
}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>

			{relatedPosts.length > 0 && (
			  <section class="related">
			    <h2>関連記事</h2>
			    <div class="related-grid">
			      {relatedPosts.map(post => (
			        <a href={`/blog/${post.id}/`}>
			          <p class="related-title">{post.data.title}</p>
			          <p class="related-date">{post.data.pubDate.toLocaleDateString('ja-JP')}</p>
			        </a>
			      ))}
			    </div>
			  </section>
			)}
		</main>
		<Footer />
	</body>
</html>
